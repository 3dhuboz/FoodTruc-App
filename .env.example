# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Gemini AI (used for image generation)
GEMINI_API_KEY=your_gemini_api_key

# Claude AI by Anthropic (used for smart schedule generation — server-side only)
# Get your key from: https://console.anthropic.com
CLAUDE_API_KEY=your_claude_api_key

# Email API Secret (used to protect server email endpoints)
EMAIL_API_SECRET=change_this_to_a_random_secret

# Amazon SES (transactional email — preferred over SMTP)
# Get credentials from: https://console.aws.amazon.com/ses
AWS_SES_ACCESS_KEY_ID=your_aws_ses_access_key_id
AWS_SES_SECRET_ACCESS_KEY=your_aws_ses_secret_access_key
AWS_SES_REGION=ap-southeast-2
SES_FROM_EMAIL=noreply@streetmeatzbbq.com.au
SES_FROM_NAME=Street Meatz BBQ

# MessageBird SMS (preferred over Twilio)
# Get API key from: https://dashboard.messagebird.com/en/developers/access
MESSAGEBIRD_API_KEY=your_messagebird_api_key
MESSAGEBIRD_ORIGINATOR=StreetMeatz

# Facebook App credentials (SERVER-SIDE only — never expose App Secret to client)
# Get from developers.facebook.com → Your App → Settings → Basic
VITE_FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
